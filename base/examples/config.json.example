{
  "device": {
    "name": "thesada-node",
    "friendly_name": "Thesada Node",
    "heartbeat_s": -1,
    "heartbeat_pin": -1,
    "charging_led": true
  },

  "web": {
    "user":     "admin",
    "password": "changeme"
  },

  "wifi": {
    "networks": [
      { "ssid": "primary-ssid",   "password": "primary-password" },
      { "ssid": "secondary-ssid", "password": "secondary-password" }
    ],
    "timeout_per_ssid_s":    10,
    "wifi_check_interval_s": 900,
    "ap_password":           "",
    "ap_timeout_s":          300,
    "static_ip": "",
    "gateway":   "192.168.1.1",
    "subnet":    "255.255.255.0",
    "dns":       "8.8.8.8"
  },

  "ntp": {
    "server":     "pool.ntp.org",
    "tz_offset_s": 3600
  },

  "mqtt": {
    "broker":           "mqtt.example.com",
    "port":             8883,
    "user":             "mqtt-user",
    "password":         "mqtt-password",
    "topic_prefix":     "thesada/node",
    "send_interval_s":  0,
    "ha_discovery":     true,
    "buffer_in":        4096,
    "buffer_out":       4096
  },

  "temperature": {
    "pin":                12,
    "interval_s":         60,
    "auto_discover":      true,
    "conversion_wait_ms": 750,
    "unit":              "C",
    "sensors": [
      { "address": "FFFFFFFFFFFFFFFF", "name": "sensor_1" }
    ]
  },

  "ads1115": {
    "line_voltage": 120,
    "i2c_sda":    1,
    "i2c_scl":    2,
    "address":    72,
    "interval_s": 60,
    "channels": [
      { "name": "house_pump", "mux": "A0_A1", "gain": 0.256 },
      { "name": "barn_pump",  "mux": "A2_A3", "gain": 0.256 }
    ]
  },

  "cellular": {
    "apn":            "OSC",
    "sim_pin":        "",
    "rf_settle_ms":   15000,
    "reg_timeout_ms": 180000
  },

  "sd": {
    "enabled":     true,
    "pin_clk":     38,
    "pin_cmd":     39,
    "pin_data":    40,
    "max_file_kb": 1024
  },

  "telegram": {
    "bot_token": "",
    "chat_ids": [],
    "cooldown_s": 300,
    "alerts": [
      {
        "enabled": true,
        "name": "overheat",
        "function": "gte",
        "value": 90.0,
        "message": "OVERHEAT",
        "sensors": []
      },
      {
        "enabled": true,
        "name": "freeze",
        "function": "lte",
        "value": 2.0,
        "message": "LOW TEMP",
        "sensors": ["temp_1", "temp_2"]
      }
    ]
  },

  "webhook": {
    "url":              "",
    "message_template": "{{value}}"
  },

  "battery": {
    "enabled":    true,
    "interval_s": 60,
    "low_pct":    20,
    "charge_ma":  300,
    "charge_v":   4.2
  },

  "display": {
    "sda":              21,
    "scl":              22,
    "address":          60,
    "page_interval_s":  3
  },

  "sleep": {
    "enabled":    false,
    "sleep_s":    300,
    "wake_s":     30
  },

  "ota": {
    "enabled":          true,
    "manifest_url":     "https://github.com/Thesada/thesada-fw/releases/latest/download/firmware.json",
    "check_interval_s": 21600,
    "cmd_topic":        "thesada/node/cmd/ota"
  },

  "lua": {
    "reload_topic":     ""
  },

  "pwm": {
    "pin":          16,
    "frequency_hz": 25000,
    "channel":      0,
    "resolution":   8
  }
}
