#!/bin/sh
# thesada-fw commit-msg guard: keep private refs out of public commits.
#
# Thin wrapper around scripts/check-commit-msg.sh. Refuses the commit when
# the message contains internal issue-tracker refs, internal hostnames, or
# RFC1918 IPs - all of which would be mirrored verbatim to the public
# GitHub repo and its release notes.
#
# Bypass:
#     MSG_OK=1 git commit ...

set -eu

repo_root="$(git rev-parse --show-toplevel)"

exec "$repo_root/scripts/check-commit-msg.sh" "$1"
