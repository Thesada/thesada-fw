#!/bin/sh
# thesada-fw pre-commit guard: invariant ledger discipline.
#
# Thin wrapper around scripts/check-invariant-ledger.sh so the local hook
# and the CI job share one matching rule. Refuses the commit when staged
# files touch load-bearing source paths without docs/invariants.md.
#
# Bypass:
#     INVARIANT_OK=1 git commit ...

set -eu

repo_root="$(git rev-parse --show-toplevel)"

git diff --cached --name-only --diff-filter=ACMR \
  | "$repo_root/scripts/check-invariant-ledger.sh"
